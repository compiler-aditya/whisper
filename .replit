run = "npm run build && npm run start"
entrypoint = "app/page.tsx"

[nix]
channel = "stable-24_05"

[env]
PORT = "3000"
HOSTNAME = "0.0.0.0"

[deployment]
run = ["sh", "-c", "npm run start"]
deploymentTarget = "cloudrun"
build = ["sh", "-c", "npm install && npm run build"]

[[ports]]
localPort = 3000
externalPort = 80
